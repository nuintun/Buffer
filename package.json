{
  "name": "@nuintun/buffer",
  "version": "0.9.0",
  "description": "A buffer tool for javascript.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./cjs/index.cjs",
      "default": "./esm/index.js"
    }
  },
  "files": [
    "cjs",
    "esm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuintun/Buffer.git"
  },
  "keywords": [
    "buffer"
  ],
  "author": {
    "name": "nuintun",
    "email": "nuintun@qq.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nuintun/Buffer/issues"
  },
  "homepage": "https://github.com/nuintun/Buffer#readme",
  "scripts": {
    "lint": "tsc --noEmit",
    "pretest": "pnpm build",
    "test": "node tests/index.ts",
    "clean": "node tools/clean.ts",
    "prepublishOnly": "pnpm build",
    "build:cjs": "rollup -c tools/rollup.cjs.ts",
    "build:esm": "rollup -c tools/rollup.esm.ts",
    "build:fix-types": "node tools/fix-types.ts",
    "build:examples": "rollup -c tools/rollup.examples.ts",
    "format": "prettier --write . --ignore-path .prettierignore",
    "build:main": "pnpm build:cjs && pnpm build:esm && pnpm build:fix-types",
    "build": "pnpm clean && pnpm build:main && pnpm build:examples && pnpm format"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.5.0",
    "dts-paths": "^2.2.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "typescript": "^6.0.2"
  }
}
